rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return signedIn() ? userDoc().data.role : null; }

    match /users/{userId} {
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
    }

    match /vendors/{vendorId} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /deliveryPartners/{partnerId} {
      allow read, create, update: if signedIn() && request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if signedIn() && (role() == "vendor" || role() == "admin") && request.resource.data.vendorId == request.auth.uid;
      allow update, delete: if signedIn() && (role() == "vendor" || role() == "admin") && resource.data.vendorId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        resource.data.deliveryPartnerId == request.auth.uid ||
        role() == "delivery"
      );
      allow update: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        resource.data.deliveryPartnerId == request.auth.uid ||
        role() == "delivery"
      );
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
    }

    match /chats/{chatId} {
      allow read, write: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;
    }
  }
}
